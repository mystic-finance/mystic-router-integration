# Mystic Swap API backend demo — copy to .env and fill in.

# Where the Mystic API is hosted
MYSTIC_BASE_URL=https://router.mysticfinance.xyz
# Optional partner API key (applies your partner fee + payout config)
# MYSTIC_API_KEY=

# The chain + wallet that executes the swap
RPC_URL=https://flare-api.flare.network/ext/C/rpc
PRIVATE_KEY=0xYOUR_TEST_KEY_WITH_A_LITTLE_GAS_AND_SELL_TOKEN
CHAIN_ID=14

# The trade. SELL_AMOUNT_HUMAN is a human amount (the demo fetches decimals via resolveToken).
# Example: 10 WFLR -> USDC.e on Flare
SELL_TOKEN=0x1D80c49BbBCd1C0911346656B529DF9E5c2F783d
BUY_TOKEN=0xFbDa5F676cB37624f28265A144A48B0d6e87d3b6
SELL_AMOUNT_HUMAN=10
SLIPPAGE_BPS=50
